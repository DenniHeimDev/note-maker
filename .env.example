# Note Maker Configuration
# Copy this file to .env and fill in your values

# Required: Your OpenAI API key
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Required: Path to folder containing presentations to process
# Example: /home/user/Documents/presentations or C:\Users\user\Documents\presentations
HOST_INPUT_PATH=/path/to/input/folder

# Required: Path to folder where generated notes will be saved
# Example: /home/user/Documents/notes or C:\Users\user\Documents\notes
HOST_OUTPUT_PATH=/path/to/output/folder

# Optional: Path to folder for backing up processed presentations
# If not set, copies will be saved to the output folder
HOST_COPY_PATH=/path/to/backup/folder
